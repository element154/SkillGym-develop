con-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"\u003e\u003cpath d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"\u003e\u003c/path\u003e\u003c/svg\u003e\u003c/a\u003e\u003c/div\u003e\n\u003cp dir=\"auto\"\u003eMany downstream tools require sorted BAM files and since they are\nslightly more compact than unsorted BAM files, you should always sorted\nBAM files. In SAMtools version 1.3 or newer, you can directly generate a\nsorted BAM file from a SAM file.\u003c/p\u003e\n\u003cdiv class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"samtools sort eg/ERR188273_chrX.sam -o eg/sorted.bam\nls -l eg/ERR188273_chrX.bam\nls -l eg/sorted.bam\"\u003e\u003cpre\u003esamtools sort eg/ERR188273_chrX.sam -o eg/sorted.bam\nls -l eg/ERR188273_chrX.bam\nls -l eg/sorted.bam\u003c/pre\u003e\u003c/div\u003e\n\u003cdiv class=\"snippet-clipboard-content notranslate position-relative overflow-auto\" data-snippet-clipboard-copy-content=\"## -rw-r--r-- 1 root root 69983526 Aug  4 00:29 eg/ERR188273_chrX.bam\n## -rw-r--r-- 1 root root 69983599 Aug  4 00:30 eg/sorted.bam\"\u003e\u003cpre class=\"notranslate\"\u003e\u003ccode\u003e## -rw-r--r-- 1 root root 69983526 Aug  4 00:29 eg/ERR188273_chrX.bam\n## -rw-r--r-- 1 root root 69983599 Aug  4 00:30 eg/sorted.bam\n\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e\n\u003cp dir=\"auto\"\u003eYou should use use additional threads (if they are available